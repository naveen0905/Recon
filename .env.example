# Copy to .env for local development. Never commit .env.
# All values are resolved from Azure Key Vault in production.

# Azure Key Vault (required — everything else is fetched from here)
AZURE_KEYVAULT_URL=https://<your-keyvault>.vault.azure.net/

# Azure Identity — local dev only (use managed identity in Azure)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# Cosmos DB (local dev fallback)
COSMOS_ENDPOINT=https://<your-cosmos>.documents.azure.com:443/
COSMOS_DATABASE=recon

# Blob Storage
BLOB_ACCOUNT_URL=https://<your-storage>.blob.core.windows.net/
BLOB_CONTAINER=recon-raw

# Azure SQL Serverless
SQL_CONNECTION_STRING=Server=<server>.database.windows.net;Database=ReconOps;Authentication=Active Directory Default

# Synapse Serverless
SYNAPSE_CONNECTION_STRING=Server=<workspace>-ondemand.sql.azuresynapse.net;Database=master;Authentication=Active Directory Default

# Service Bus
SERVICEBUS_NAMESPACE=<your-namespace>.servicebus.windows.net
SERVICEBUS_QUEUE=retrigger-jobs

# Container App workers — set to one of: connector-worker | staleness-timer | change-feed
WORKER_TYPE=connector-worker

# Python agent LLM provider
AGENT_LLM_PROVIDER=anthropic          # or azure_openai
ANTHROPIC_API_KEY=                     # local dev only — use Key Vault in Azure
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_KEY=                  # local dev only — use Key Vault in Azure
